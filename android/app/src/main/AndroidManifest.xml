package com.smrihamza0008.openthepath;

import androidx.annotation.NonNull;
import io.flutter.embedding.android.FlutterActivity;
import io.flutter.embedding.engine.FlutterEngine;
import io.flutter.plugin.common.MethodChannel;

public class MainActivity extends FlutterActivity {
    private static final String CHANNEL = "com.smrihamza0008.openthepath/path";

    @Override
    public void configureFlutterEngine(@NonNull FlutterEngine flutterEngine) {
        super.configureFlutterEngine(flutterEngine);

        // تعديل طريقة الوصول للـ BinaryMessenger لتتوافق تماماً مع إصدار 3.13.0
        new MethodChannel(flutterEngine.getDartExecutor(), CHANNEL)
            .setMethodCallHandler(new MethodChannel.MethodCallHandler() {
                @Override
                public void onMethodCall(@NonNull io.flutter.plugin.common.MethodCall call, @NonNull MethodChannel.Result result) {
                    if (call.method.equals("checkPath")) {
                        Object pathArgument = call.argument("path");
                        Object paramArgument = call.argument("param");

                        String targetPath = (pathArgument != null) ? pathArgument.toString() : "";
                        String param = (paramArgument != null) ? paramArgument.toString() : "";

                        if (!targetPath.isEmpty()) {
                            result.success(true);
                        } else {
                            result.error("INVALID_PATH", "Path cannot be empty", null);
                        }
                    } else {
                        result.notImplemented();
                    }
                }
            });
    }
}
